# Local-only prototype.
# Warning: values used by the extension build can be inspected from the built extension.
# OCR provider selector. Allowed values are the exact string in WXT_OPENAI_NAME or WXT_GEMINI_NAME.
WXT_OCR_PROVIDER=openai

# OpenAI provider name. Any non-empty string is allowed; WXT_OCR_PROVIDER must equal this value to use OpenAI.
WXT_OPENAI_NAME=openai
# OpenAI API key used only when WXT_OCR_PROVIDER matches WXT_OPENAI_NAME.
WXT_OPENAI_API_KEY=sk-proj-replace-me
# OpenAI vision-capable model for OCR. Use a model name supported by the OpenAI Responses API.
WXT_OPENAI_MODEL=gpt-4.1-mini
# OpenAI image detail level. Allowed values: low, high, auto. high is usually better for small noisy CAPTCHA images.
WXT_OPENAI_IMAGE_DETAIL=high
# OpenAI Responses API endpoint. Must be a valid URL; usually leave this as the default official endpoint.
WXT_OPENAI_RESPONSES_ENDPOINT=https://api.openai.com/v1/responses

# Gemini provider name. Any non-empty string is allowed; WXT_OCR_PROVIDER must equal this value to use Gemini.
WXT_GEMINI_NAME=gemini
# Gemini API key used only when WXT_OCR_PROVIDER matches WXT_GEMINI_NAME.
WXT_GEMINI_API_KEY=replace-me
# Gemini vision-capable model for OCR. Use a Gemini model that supports image input, such as gemini-2.5-flash for speed or gemini-2.5-pro for harder samples.
WXT_GEMINI_MODEL=gemini-2.5-flash
# Maximum Gemini output tokens, including thinking tokens on Gemini 2.5 models. Positive integer; for OCR try 256-1024. Increase if responses end with MAX_TOKENS.
WXT_GEMINI_MAX_OUTPUT_TOKENS=512
# Gemini thinking token budget. Gemini 2.5 Flash: 0-24576, where 0 disables thinking. Gemini 2.5 Pro: 128-32768, cannot disable thinking. -1 enables dynamic thinking.
WXT_GEMINI_THINKING_BUDGET=0
# Gemini request timeout in milliseconds. Positive integer; 10000-60000 is practical. Prevents the OCR button from staying pending indefinitely.
WXT_GEMINI_TIMEOUT_MS=30000
# Gemini API endpoint base URL. Must be a valid URL; usually leave this as the default official endpoint.
WXT_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# Image upscaling factor before OCR. Integer range: 1-8; values outside this range are clamped. Higher values can improve readability but increase request size.
WXT_OCR_IMAGE_SCALE=4
